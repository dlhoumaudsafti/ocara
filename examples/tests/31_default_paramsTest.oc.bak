// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 31_default_params.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest

function greet(name:string = "World"): string {
    return "Hello, " + name + "!"
}

function add(a:int, b:int = 0, c:int = 0): int {
    return a + b + c
}

function format(text:string, prefix:string = "[", suffix:string = "]"): string {
    return prefix + text + suffix
}

class Test_31_default_params {
    
    public method defaultParamTest(): int {
        UnitTest::assertEquals("Hello, World!", greet())
        UnitTest::assertEquals("Hello, Ocara!", greet("Ocara"))
        return 0
    }
    
    public method multipleDefaultsTest(): int {
        UnitTest::assertEquals(5, add(5))
        UnitTest::assertEquals(8, add(5, 3))
        UnitTest::assertEquals(10, add(5, 3, 2))
        return 0
    }
    
    public method formatDefaultsTest(): int {
        UnitTest::assertEquals("[test]", format("test"))
        UnitTest::assertEquals("<test]", format("test", "<"))
        UnitTest::assertEquals("<test>", format("test", "<", ">"))
        return 0
    }
    
    public method mainTest(): int {
        UnitTest::assertEquals("Hello, World!", greet())
        UnitTest::assertEquals("Hello, Ocara!", greet("Ocara"))
        UnitTest::assertEquals(5, add(5))
        UnitTest::assertEquals(8, add(5, 3))
        UnitTest::assertEquals(10, add(5, 3, 2))
        UnitTest::assertEquals("[test]", format("test"))
        return 0
    }
}
