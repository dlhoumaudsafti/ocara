// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 05_switch.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest
import ocara.IO

function http_status(code:int): void {
    switch code {
        200 {
            IO::writeln("200 OK")
        }
        201 {
            IO::writeln("201 Created")
        }
        400 {
            IO::writeln("400 Bad Request")
        }
        401 {
            IO::writeln("401 Unauthorized")
        }
        404 {
            IO::writeln("404 Not Found")
        }
        500 {
            IO::writeln("500 Internal Server Error")
        }
        default {
            IO::writeln("Code HTTP inconnu")
        }
    }
}

function day_type(day:string): void {
    switch day {
        "samedi" {
            IO::writeln("Week-end")
        }
        "dimanche" {
            IO::writeln("Week-end")
        }
        default {
            IO::writeln("Jour de semaine")
        }
    }
}

class Test_05_switch {
    
    public method switchIntTest(): int {
        var day:int = 2
        var result:string = ""
        
        switch day {
            1 {
                result = "lundi"
            }
            2 {
                result = "mardi"
            }
            3 {
                result = "mercredi"
            }
            default {
                result = "autre"
            }
        }
        
        UnitTest::assertEquals("mardi", result)
        return 0
    }
    
    public method switchStringTest(): int {
        var fruit:string = "pomme"
        var color:string = ""
        
        switch fruit {
            "pomme" {
                color = "rouge"
            }
            "banane" {
                color = "jaune"
            }
            "orange" {
                color = "orange"
            }
            default {
                color = "inconnu"
            }
        }
        
        UnitTest::assertEquals("rouge", color)
        return 0
    }
    
    public method switchDefaultTest(): int {
        var n:int = 999
        var result:string = ""
        
        switch n {
            1 {
                result = "un"
            }
            2 {
                result = "deux"
            }
            default {
                result = "autre"
            }
        }
        
        UnitTest::assertEquals("autre", result)
        return 0
    }
    
    public method http_statusTest(): int {
        // Appelle http_status pour assurer la couverture
        http_status(200)
        http_status(201)
        http_status(400)
        http_status(401)
        http_status(404)
        http_status(500)
        http_status(999)
        return 0
    }
    
    public method day_typeTest(): int {
        // Appelle day_type pour assurer la couverture
        day_type("lundi")
        day_type("mardi")
        day_type("samedi")
        day_type("dimanche")
        return 0
    }
    
    public method mainTest(): int {
        // Reproduit le comportement de main()
        http_status(200)
        http_status(404)
        http_status(999)
        day_type("lundi")
        day_type("samedi")
        
        var niveau:int = 3
        var result:string = ""
        switch niveau {
            1 {
                result = "Débutant"
            }
            2 {
                result = "Intermédiaire"
            }
            3 {
                result = "Avancé"
            }
            default {
                result = "Niveau inconnu"
            }
        }
        UnitTest::assertEquals("Avancé", result)
        return 0
    }
}
