// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 16_types.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest
import ocara.Array

class Vector2 {
    public property x:float
    public property y:float
    init(x:float, y:float) {
        self.x = x
        self.y = y
    }
}

class Test_16_types {
    
    public method primitivesTest(): int {
        var i:int = 42
        var f:float = 3.14
        var s:string = "Ocara"
        var b:bool = true
        
        UnitTest::assertEquals(42, i)
        UnitTest::assertNotNull(f)
        UnitTest::assertEquals("Ocara", s)
        UnitTest::assertTrue(b)
        
        return 0
    }
    
    public method mixedTest(): int {
        var a:mixed = "text"
        UnitTest::assertNotNull(a)
        
        a = 100
        UnitTest::assertNotNull(a)
        
        a = false
        UnitTest::assertNotNull(a)
        
        return 0
    }
    
    public method arraysTest(): int {
        var ints:int[] = [1, 2, 3]
        var strs:string[] = ["a", "b", "c"]
        
        UnitTest::assertEquals(1, ints[0])
        UnitTest::assertEquals("b", strs[1])
        
        return 0
    }
    
    public method mainTest(): int {
        var i:int = 42
        var f:float = 3.14
        var s:string = "Ocara"
        var b:bool = true
        var a:mixed = "text"
        
        UnitTest::assertEquals(42, i)
        UnitTest::assertNotNull(f)
        UnitTest::assertEquals("Ocara", s)
        UnitTest::assertTrue(b)
        UnitTest::assertNotNull(a)
        
        a = 100
        a = false
        
        var ints:int[] = [1, 2, 3]
        var strs:string[] = ["a", "b", "c"]
        var bools:bool[] = [true, false, true]
        var vals:mixed[] = [1, "deux", 3.0, false]
        var matrix:int[][] = [[1, 2], [3, 4]]
        
        UnitTest::assertEquals(1, ints[0])
        UnitTest::assertEquals("b", strs[1])
        UnitTest::assertTrue(bools[2])
        UnitTest::assertNotNull(vals[1])
        
        var config:map<string, mixed> = {
            "debug": true,
            "version": 1,
            "name": "app"
        }
        UnitTest::assertNotNull(config["debug"])
        UnitTest::assertNotNull(config["version"])
        
        var v:Vector2 = use Vector2(1.0, 2.5)
        UnitTest::assertNotNull(v.x)
        UnitTest::assertNotNull(v.y)
        
        return 0
    }
}
