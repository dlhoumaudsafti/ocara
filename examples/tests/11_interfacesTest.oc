import ocara.UnitTest
import ocara.IO
import Circle from "11_interfaces.oc"
import Rectangle from "11_interfaces.oc"

class Test_11_interfaces {

    private property circle:Circle
    private property rectangle:Rectangle

    init() {
        // Nécessaire pour que les classes soient chargées avant les tests
        self.circle = use Circle(5.0)
        self.rectangle = use Rectangle(4.0, 6.0)
    }
    
    public method areaTest(): int {
        var area:float = self.circle.area()
        UnitTest::assertEquals(area, 78.53975)
        
        var rectArea:float = self.rectangle.area()
        UnitTest::assertEquals(rectArea, 24.0)
        return 0
    }
    
    public method perimeterTest(): int {
        var perimeter:float = self.circle.perimeter()
        UnitTest::assertEquals(perimeter, 31.4159)
        
        var rectPerimeter:float = self.rectangle.perimeter()
        UnitTest::assertEquals(rectPerimeter, 20.0)
        return 0
    }

    public method describeTest(): int {
        self.circle.describe()
        self.rectangle.describe()
        return 0
    }

    public method print_infoTest(): int {
        self.circle.print_info()
        self.rectangle.print_info()
        return 0
    }
    
    public method mainTest(): int {
        return 0
    }
}

