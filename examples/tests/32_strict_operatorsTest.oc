// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 32_strict_operators.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest

class Test_32_strict_operators {
    
    public method strictEqualityTest(): int {
        var x:int = 42
        var z:int = 42
        
        UnitTest::assertTrue(x === z)
        UnitTest::assertTrue(x egal z)
        return 0
    }
    
    public method strictInequalityTest(): int {
        var a:int = 10
        var b:float = 10.0
        var c:int = 20
        
        UnitTest::assertTrue(a !== b)
        UnitTest::assertTrue(a not egal b)
        UnitTest::assertTrue(a !== c)
        return 0
    }
    
    public method strictComparisonTest(): int {
        var num1:int = 100
        var num2:int = 200
        
        UnitTest::assertTrue(num1 <== num2)
        UnitTest::assertTrue(num2 >== num1)
        return 0
    }
    
    public method mainTest(): int {
        var x:int = 42
        var z:int = 42
        UnitTest::assertTrue(x === z)
        UnitTest::assertTrue(x egal z)
        
        var a:int = 10
        var b:float = 10.0
        UnitTest::assertTrue(a !== b)
        UnitTest::assertTrue(a not egal b)
        
        var num1:int = 100
        var num2:int = 200
        UnitTest::assertTrue(num1 <== num2)
        UnitTest::assertTrue(num2 >== num1)
        
        return 0
    }
}
