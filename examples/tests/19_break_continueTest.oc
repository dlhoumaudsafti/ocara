// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 19_break_continue.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest

class Test_19_break_continue {
    
    public method breakTest(): int {
        var sum:int = 0
        var i:int = 0
        while i < 10 {
            if i == 5 {
                break
            }
            sum = sum + i
            i = i + 1
        }
        UnitTest::assertEquals(10, sum)  // 0+1+2+3+4 = 10
        return 0
    }
    
    public method continueTest(): int {
        var sum:int = 0
        for i in 0..6 {
            if i == 2 {
                continue
            }
            sum = sum + i
        }
        UnitTest::assertEquals(13, sum)  // 0+1+3+4+5 = 13 (skip 2)
        return 0
    }
    
    public method nestedBreakTest(): int {
        var count:int = 0
        var i:int = 0
        while i < 3 {
            var j:int = 0
            while j < 5 {
                if j == 2 {
                    break
                }
                count = count + 1
                j = j + 1
            }
            i = i + 1
        }
        UnitTest::assertEquals(6, count)  // 3 * 2 = 6
        return 0
    }
}
