// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 05_switch.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest

class Test_05_switch {
    
    public method switchIntTest(): int {
        var day:int = 2
        var result:string = ""
        
        switch day {
            1 {
                result = "lundi"
            }
            2 {
                result = "mardi"
            }
            3 {
                result = "mercredi"
            }
            default {
                result = "autre"
            }
        }
        
        UnitTest::assertEquals("mardi", result)
        return 0
    }
    
    public method switchStringTest(): int {
        var fruit:string = "pomme"
        var color:string = ""
        
        switch fruit {
            "pomme" {
                color = "rouge"
            }
            "banane" {
                color = "jaune"
            }
            "orange" {
                color = "orange"
            }
            default {
                color = "inconnu"
            }
        }
        
        UnitTest::assertEquals("rouge", color)
        return 0
    }
    
    public method switchDefaultTest(): int {
        var n:int = 999
        var result:string = ""
        
        switch n {
            1 {
                result = "un"
            }
            2 {
                result = "deux"
            }
            default {
                result = "autre"
            }
        }
        
        UnitTest::assertEquals("autre", result)
        return 0
    }
}
