// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 07_loops.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest

class Test_07_loops {
    
    public method whileLoopTest(): int {
        var sum:int = 0
        var i:int = 1
        while i <= 5 {
            sum = sum + i
            i = i + 1
        }
        UnitTest::assertEquals(15, sum)  // 1+2+3+4+5 = 15
        return 0
    }
    
    public method forRangeTest(): int {
        var sum:int = 0
        for i in 1..6 {
            sum = sum + i
        }
        UnitTest::assertEquals(15, sum)  // 1+2+3+4+5 = 15
        return 0
    }
    
    public method forArrayTest(): int {
        var numbers:int[] = [10, 20, 30]
        var sum:int = 0
        for n in numbers {
            sum = sum + n
        }
        UnitTest::assertEquals(60, sum)
        return 0
    }
    
    public method nestedLoopTest(): int {
        var count:int = 0
        var i:int = 0
        while i < 3 {
            var j:int = 0
            while j < 2 {
                count = count + 1
                j = j + 1
            }
            i = i + 1
        }
        UnitTest::assertEquals(6, count)  // 3 * 2 = 6
        return 0
    }
}
