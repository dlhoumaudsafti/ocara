// ─────────────────────────────────────────────────────────────────────────────
// Tests unitaires pour 15_operators.oc
// ─────────────────────────────────────────────────────────────────────────────

import ocara.UnitTest

class Test_15_operators {
    
    public method arithmeticTest(): int {
        UnitTest::assertEquals(13, 10 + 3)
        UnitTest::assertEquals(7, 10 - 3)
        UnitTest::assertEquals(30, 10 * 3)
        UnitTest::assertEquals(3, 10 / 3)
        UnitTest::assertEquals(1, 10 % 3)
        return 0
    }
    
    public method precedenceTest(): int {
        UnitTest::assertEquals(14, 2 + 3 * 4)
        UnitTest::assertEquals(20, (2 + 3) * 4)
        UnitTest::assertEquals(5, 10 - 2 * 3 + 1)
        return 0
    }
    
    public method unaryTest(): int {
        var n:int = 5
        UnitTest::assertEquals(-5, -n)
        UnitTest::assertEquals(5, -(-n))
        return 0
    }
    
    public method comparisonTest(): int {
        UnitTest::assertTrue(5 == 5)
        UnitTest::assertTrue(5 != 3)
        UnitTest::assertTrue(5 < 10)
        UnitTest::assertTrue(5 <= 5)
        UnitTest::assertTrue(10 > 5)
        UnitTest::assertTrue(10 >= 10)
        return 0
    }
    
    public method logicalTest(): int {
        UnitTest::assertTrue(true and true)
        UnitTest::assertFalse(true and false)
        UnitTest::assertTrue(false or true)
        UnitTest::assertFalse(false or false)
        UnitTest::assertTrue(not false)
        UnitTest::assertFalse(not true)
        return 0
    }
}
